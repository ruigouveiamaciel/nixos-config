{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "instructions": [],
  "plugin": [
    "opencode-claude-auth@1.4.9",
    "@mohak34/opencode-notifier@0.2.0"
  ],
  "permission": {
    "*": "ask",
    "task": {
      "*": "ask",
      "general": "allow",
      "explore": "allow"
    },
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "lsp": "allow",
    "skill": {
      "*": "ask",
      "caveman": "allow",
      "caveman-commit": "allow"
    },
    "webfetch": "allow",
    "websearch": "allow",
    "codesearch": "allow",
    "question": "allow",
    "read": {
      "*": "deny",
      "*.nix": "allow",
      "*.md": "allow",
      "*.txt": "allow",
      "*.html": "allow",
      "*.css": "allow",
      "*.scss": "allow",
      "*.sass": "allow",
      "*.rs": "allow",
      "*.go": "allow",
      "*.java": "allow",
      "*.c": "allow",
      "*.cpp": "allow",
      "*.h": "allow",
      "*.hpp": "allow",
      "*.svg": "allow",
      "*.ts": "allow",
      "*.tsx": "allow",
      "*.js": "allow",
      "*.jsx": "allow",
      "*.mjs": "allow",
      "*.py": "allow",
      "Makefile": "allow",
      "Dockerfile": "allow",
      "*.json": "ask",
      "*.toml": "ask",
      "*.yaml": "ask",
      "*.yml": "ask",
      "*.xml": "ask",
      "*.conf": "ask",
      "*.cfg": "ask",
      "*.ini": "ask",
      "*.sh": "ask"
    },
    "external_directory": {
      "*": "deny",
      "$HOME/repos/*": "ask",
      "$HOME/projects/*": "ask"
    },
    "bash": {
      "*": "deny",
      "glab *": "ask",
      "gh *": "ask",
      "cargo *": "ask",
      "rustup *": "ask",
      "nix *": "ask",
      "nixos-rebuild build*": "ask",
      "nixos-rebuild dry-build*": "ask",
      "npm *": "ask",
      "pnpm *": "ask",
      "yarn *": "ask",
      "bun *": "ask",
      "go *": "ask",
      "make *": "ask",
      "curl *": "ask",
      "jq *": "ask",
      "diff *": "ask",
      "stat *": "ask",
      "wc *": "ask",
      "python *": "ask",
      "python3 *": "ask",
      "node *": "ask",
      "git add *": "ask",
      "git rm *": "ask",
      "git mv *": "ask",
      "git commit*": "ask",
      "git push*": "ask",
      "git fetch*": "ask",
      "git pull*": "ask",
      "git checkout*": "ask",
      "git switch*": "ask",
      "git merge*": "ask",
      "git rebase*": "ask",
      "git cherry-pick*": "ask",
      "git stash*": "ask",
      "git tag *": "ask",
      "pwd": "allow",
      "date": "allow",
      "date *": "allow",
      "sleep *": "allow",
      "which *": "allow",
      "uname": "allow",
      "uname *": "allow",
      "whoami": "allow",
      "nix --version": "allow",
      "git --version": "allow",
      "git version": "allow",
      "cargo --version": "allow",
      "cargo version": "allow",
      "rustc --version": "allow",
      "rustup --version": "allow",
      "rustup show": "allow",
      "node --version": "allow",
      "node -v": "allow",
      "npm --version": "allow",
      "npm -v": "allow",
      "pnpm --version": "allow",
      "pnpm -v": "allow",
      "yarn --version": "allow",
      "bun --version": "allow",
      "bun -v": "allow",
      "python --version": "allow",
      "python -V": "allow",
      "python3 --version": "allow",
      "python3 -V": "allow",
      "go version": "allow",
      "git status*": "allow",
      "git log*": "allow",
      "git diff*": "allow",
      "git show*": "allow",
      "git branch": "allow",
      "git branch -r*": "allow",
      "git branch -a*": "allow",
      "git branch -v*": "allow",
      "git branch -l*": "allow",
      "git branch --show-current": "allow",
      "git branch --list*": "allow",
      "git remote": "allow",
      "git remote -v*": "allow",
      "git remote show*": "allow",
      "git remote get-url*": "allow",
      "git ls-files*": "allow",
      "git describe*": "allow",
      "git shortlog*": "allow",
      "git rev-list*": "allow",
      "git blame*": "allow",
      "git stash list": "allow",
      "git stash show*": "allow",
      "git tag": "allow",
      "git tag -l*": "allow",
      "glab mr view*": "allow",
      "glab mr list*": "allow",
      "glab issue view*": "allow",
      "glab issue list*": "allow",
      "glab ci view*": "allow",
      "glab ci list*": "allow",
      "glab pipeline view*": "allow",
      "glab pipeline list*": "allow",
      "glab repo view*": "allow",
      "git push --force*": "deny",
      "git push -f*": "deny",
      "curl * | *sh*": "deny",
      "echo *": "deny",
      "printf *": "deny",
      "cat *": "deny",
      "head *": "ask",
      "tail *": "ask",
      "less *": "deny",
      "more *": "deny",
      "ls *": "deny",
      "ls": "deny",
      "find *": "deny",
      "grep *": "deny",
      "rg *": "deny",
      "sed *": "deny",
      "awk *": "deny"
    },
    "nixos_nix": "allow",
    "atlassian_atlassianUserInfo": "allow",
    "atlassian_get*": "allow",
    "atlassian_lookup*": "allow",
    "atlassian_search*": "allow",
    "atlassian_fetch*": "allow",
    "sentry_whoami": "allow",
    "sentry_get_*": "allow",
    "sentry_find_*": "allow",
    "sentry_search_*": "allow",
    "sentry_analyze_issue_with_seer": "allow"
  },
  "agent": {
    "plan": {
      "model": "anthropic/claude-sonnet-4-6",
      "variant": "high"
    },
    "build": {
      "model": "anthropic/claude-haiku-4-5",
      "variant": "high"
    }
  },
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      }
    }
  },
  "mcp": {
    "nixos": {
      "enabled": false,
      "type": "local",
      "command": [
        "mcp-nixos"
      ]
    },
    "atlassian": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/sse"
    },
    "sentry": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.sentry.dev/mcp"
    },
    "playwright": {
      "enabled": false,
      "type": "local",
      "command": [
        "pnpx",
        "-y",
        "@playwright/mcp@latest"
      ]
    }
  }
}

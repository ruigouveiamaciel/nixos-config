{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "plugin": [
    "opencode-claude-bridge@1.8.0",
    "opencode-lmstudio@0.3.0",
    "@mohak34/opencode-notifier@0.2.0"
  ],
  "permission": {
    "*": "ask",
    "task": {
      "*": "ask",
      "general": "allow",
      "explore": "allow"
    },
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "lsp": "allow",
    "skill": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "codesearch": "allow",
    "question": "allow",
    "nixos_nix": "allow",
    "atlassian_atlassianUserInfo": "allow",
    "atlassian_getAccessibleAtlassianResources": "allow",
    "atlassian_getConfluencePage": "allow",
    "atlassian_searchConfluenceUsingCql": "allow",
    "atlassian_getConfluenceSpaces": "allow",
    "atlassian_getPagesInConfluenceSpace": "allow",
    "atlassian_getConfluencePageFooterComments": "allow",
    "atlassian_getConfluencePageInlineComments": "allow",
    "atlassian_getConfluenceCommentChildren": "allow",
    "atlassian_getConfluencePageDescendants": "allow",
    "atlassian_getJiraIssue": "allow",
    "atlassian_getTransitionsForJiraIssue": "allow",
    "atlassian_getJiraIssueRemoteIssueLinks": "allow",
    "atlassian_getVisibleJiraProjects": "allow",
    "atlassian_getJiraProjectIssueTypesMetadata": "allow",
    "atlassian_getJiraIssueTypeMetaWithFields": "allow",
    "atlassian_searchJiraIssuesUsingJql": "allow",
    "atlassian_lookupJiraAccountId": "allow",
    "atlassian_getIssueLinkTypes": "allow",
    "atlassian_searchAtlassian": "allow",
    "atlassian_fetchAtlassian": "allow",
    "sentry_whoami": "allow",
    "sentry_find_organizations": "allow",
    "sentry_find_teams": "allow",
    "sentry_find_projects": "allow",
    "sentry_find_releases": "allow",
    "sentry_get_issue_tag_values": "allow",
    "sentry_get_event_attachment": "allow",
    "sentry_search_events": "allow",
    "sentry_search_issues": "allow",
    "sentry_search_issue_events": "allow",
    "sentry_get_profile_details": "allow",
    "sentry_get_sentry_resource": "allow",
    "sentry_analyze_issue_with_seer": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny"
    },
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "pwd": "allow",
      "echo *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "stat *": "allow",
      "which *": "allow",
      "find *": "allow",
      "xargs *": "allow",
      "sort *": "allow",
      "jq *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "mkdir *": "allow",
      "git status*": "allow",
      "git log*": "allow",
      "git diff*": "allow",
      "git show*": "allow",
      "git branch*": "allow",
      "git ls-files*": "allow",
      "git ls-tree*": "allow",
      "git blame*": "allow",
      "git tag --list*": "allow",
      "git tag -l*": "allow",
      "npm list*": "allow",
      "npm ls*": "allow",
      "npm view*": "allow",
      "npm search*": "allow",
      "npm outdated*": "allow",
      "yarn list*": "allow",
      "pnpm list*": "allow",
      "cargo --version": "allow",
      "cargo version": "allow",
      "cargo search*": "allow",
      "rustc --version": "allow",
      "node --version": "allow",
      "node -v": "allow",
      "npm --version": "allow",
      "npm -v": "allow",
      "python --version": "allow",
      "python -V": "allow",
      "python3 --version": "allow",
      "python3 -V": "allow",
      "go version": "allow",
      "java -version": "allow",
      "javac -version": "allow",
      "gcc --version": "allow",
      "g++ --version": "allow",
      "clang --version": "allow",
      "make --version": "allow",
      "cmake --version": "allow",
      "docker --version": "allow",
      "docker version": "allow",
      "docker ps*": "allow",
      "docker images*": "allow",
      "docker inspect*": "allow",
      "date": "allow",
      "sleep *": "allow",
      "rm *": "deny",
      "rm": "deny",
      "rmdir *": "deny",
      "mv *": "deny",
      "cp * /*": "deny",
      "dd *": "deny",
      "mkfs*": "deny",
      "fdisk*": "deny",
      "parted*": "deny",
      "chmod 777*": "deny",
      "chmod -R 777*": "deny",
      "chown -R*": "deny",
      "curl * | sh*": "deny",
      "curl * | bash*": "deny",
      "wget * | sh*": "deny",
      "wget * | bash*": "deny",
      ":(){ :|:& };:": "deny",
      "git push --force*": "deny",
      "git push -f*": "deny",
      "git reset --hard*": "deny",
      "git clean -fd*": "deny",
      "docker rm -f*": "deny",
      "docker rmi -f*": "deny",
      "killall*": "deny",
      "pkill*": "deny"
    }
  },
  "agent": {
    "plan": {
      "model": "anthropic/claude-sonnet-4-6"
    },
    "build": {
      "model": "anthropic/claude-haiku-4-5",
      "permission": {
        "bash": {
          "git fetch origin main": "allow",
          "git fetch origin master": "allow",
          "git checkout *": "allow",
          "git add *": "allow",
          "git rm *": "allow"
        }
      }
    },
    "gitlab": {
      "mode": "primary",
      "model": "anthropic/claude-haiku-4-5",
      "permission": {
        "bash": {
          "glab api user": "allow",
          "glab mr create *": "allow",
          "glab mr update *": "allow",
          "glab ci trace *": "allow",
          "glab api /projects/*/merge_requests": "allow",
          "glab api /projects/*/merge_requests/*": "allow",
          "glab api /projects/*/merge_requests/*/discussions": "allow",
          "glab api /projects/*/merge_requests/*/discussions/*": "allow",
          "glab api /projects/*/merge_requests/*/discussions/*/notes": "allow",
          "glab api /projects/*/merge_requests/*/discussions/*/notes/*": "allow",
          "glab api -X POST /projects/*/merge_requests/*/discussions/*/notes": "allow",
          "glab api -X PUT /projects/*/merge_requests/*/discussions/*": "allow",
          "glab api /projects/*/pipelines/*/jobs": "allow",
          "glab api /projects/*/jobs/*/trace": "allow"
        }
      }
    }
  },
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      }
    }
  },
  "mcp": {
    "nixos": {
      "enabled": false,
      "type": "local",
      "command": [
        "nix",
        "run",
        "github:utensils/mcp-nixos",
        "--"
      ]
    },
    "atlassian": {
      "enabled": false,
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "https://mcp.atlassian.com/v1/sse"
      ]
    },
    "sentry": {
      "enabled": false,
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "https://mcp.sentry.dev/mcp"
      ]
    },
    "playwright": {
      "enabled": false,
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ]
    },
    "context7": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    }
  }
}

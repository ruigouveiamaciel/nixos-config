{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "plugin": [
    "@ex-machina/opencode-anthropic-auth@1.7.5",
    "@mohak34/opencode-notifier@0.2.0"
  ],
  "tools": {
    "glob": false,
    "grep": false,
    "list": false,
    "todoread": false,
    "todowrite": false,
    "lsp": false,
    "question": false,
    "codesearch": false
  },
  "permission": {
    "*": "ask",
    "task": "allow",
    "skill": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "read": {
      "*": "ask",
      "*.nix": "allow",
      "*.md": "allow",
      "*.txt": "allow",
      "*.html": "allow",
      "*.css": "allow",
      "*.scss": "allow",
      "*.sass": "allow",
      "*.rs": "allow",
      "*.go": "allow",
      "*.java": "allow",
      "*.c": "allow",
      "*.cpp": "allow",
      "*.h": "allow",
      "*.hpp": "allow",
      "*.svg": "allow",
      "*.ts": "allow",
      "*.tsx": "allow",
      "*.js": "allow",
      "*.jsx": "allow",
      "*.mjs": "allow",
      "*.py": "allow"
    },
    "external_directory": {
      "*": "deny",
      "$HOME/repos/*": "ask",
      "$HOME/projects/*": "ask",
      "$HOME/.local/share/opencode/tool-output/*": "allow"
    },
    "bash": {
      "*": "ask",
      "pwd": "allow",
      "date": "allow",
      "date *": "allow",
      "sleep *": "allow",
      "which *": "allow",
      "uname": "allow",
      "uname *": "allow",
      "whoami": "allow",
      "git push --force*": "deny",
      "git push -f*": "deny",
      "sudo *": "deny",
      "rm -rf*": "deny",
      "rm -fr*": "deny",
      "less *": "deny",
      "more *": "deny",
      "awk *": "deny"
    }
  },
  "agent": {
    "plan": {
      "model": "anthropic/claude-sonnet-4-5",
      "variant": "high"
    },
    "build": {
      "model": "anthropic/claude-sonnet-4-5",
      "variant": "high"
    }
  },
  "mcp": {
    "nixos": {
      "enabled": false,
      "type": "local",
      "command": [
        "mcp-nixos"
      ]
    },
    "atlassian": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/sse"
    },
    "sentry": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.sentry.dev/mcp"
    }
  }
}

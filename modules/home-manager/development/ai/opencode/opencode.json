{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "permission": {
    "*": "ask",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "lsp": "allow",
    "skill": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "question": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny"
    },
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "pwd": "allow",
      "echo *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "stat *": "allow",
      "which *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "git status*": "allow",
      "git log*": "allow",
      "git diff*": "allow",
      "git show*": "allow",
      "git branch*": "allow",
      "git ls-files*": "allow",
      "git ls-tree*": "allow",
      "git blame*": "allow",
      "git tag --list*": "allow",
      "git tag -l*": "allow",
      "npm list*": "allow",
      "npm ls*": "allow",
      "npm view*": "allow",
      "npm search*": "allow",
      "npm outdated*": "allow",
      "yarn list*": "allow",
      "pnpm list*": "allow",
      "cargo --version": "allow",
      "cargo version": "allow",
      "cargo search*": "allow",
      "rustc --version": "allow",
      "node --version": "allow",
      "node -v": "allow",
      "npm --version": "allow",
      "npm -v": "allow",
      "python --version": "allow",
      "python -V": "allow",
      "python3 --version": "allow",
      "python3 -V": "allow",
      "go version": "allow",
      "java -version": "allow",
      "javac -version": "allow",
      "gcc --version": "allow",
      "g++ --version": "allow",
      "clang --version": "allow",
      "make --version": "allow",
      "cmake --version": "allow",
      "docker --version": "allow",
      "docker version": "allow",
      "docker ps*": "allow",
      "docker images*": "allow",
      "docker inspect*": "allow",
      "date": "allow",
      "rm *": "deny",
      "rm": "deny",
      "rmdir *": "deny",
      "mv *": "deny",
      "cp * /*": "deny",
      "dd *": "deny",
      "mkfs*": "deny",
      "fdisk*": "deny",
      "parted*": "deny",
      "chmod 777*": "deny",
      "chmod -R 777*": "deny",
      "chown -R*": "deny",
      "curl * | sh*": "deny",
      "curl * | bash*": "deny",
      "wget * | sh*": "deny",
      "wget * | bash*": "deny",
      ":(){ :|:& };:": "deny",
      "git push --force*": "deny",
      "git push -f*": "deny",
      "git reset --hard*": "deny",
      "git clean -fd*": "deny",
      "docker rm -f*": "deny",
      "docker rmi -f*": "deny",
      "killall*": "deny",
      "pkill*": "deny"
    }
  },
  "mcp": {
    "atlassian": {
      "enabled": false,
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "https://mcp.atlassian.com/v1/sse"
      ]
    }
  }
}
